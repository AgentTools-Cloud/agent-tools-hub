# --- service ---
LISTEN_HOST=0.0.0.0
LISTEN_PORT=9300
PUBLIC_URL=https://hub.agent-tools.cloud

# --- upstream facilitator (our own; see JoursBleu/facilitator) ---
# Gateway calls this to verify + settle the buyer's x402 payment.
# Money settles directly to the seller's payTo — the hub never holds funds.
FACILITATOR_URL=https://facilitator.agent-tools.cloud

# --- chain / asset (Base mainnet defaults) ---
NETWORK=eip155:8453
USDC_ADDRESS_BASE=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# --- master key for encrypting sellers' upstream auth secrets at rest ---
# Generate with: python3 scripts/gen_keys.py
# Keep this file chmod 600. DO NOT COMMIT. Losing it = all stored upstream keys unreadable.
FERNET_KEY=

# --- admin token for the seller-approval / listing API ---
# Generate with: python3 scripts/gen_keys.py
ADMIN_TOKEN=

# --- ops ---
LOG_LEVEL=INFO
DB_PATH=/var/lib/agent-tools-hub/hub.db

# --- directory mirror (optional): push approved listings into agent-tools.cloud ---
DIRECTORY_SUBMIT_URL=
DIRECTORY_SUBMIT_TOKEN=
