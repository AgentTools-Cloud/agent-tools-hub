# --- service ---
LISTEN_HOST=0.0.0.0
LISTEN_PORT=9300
PUBLIC_URL=https://hub.agent-tools.cloud

# --- upstream facilitator (verify + settle; money settles straight to seller payTo) ---
# Pick a preset name OR paste a full URL. Each preset auto-sets NETWORK + USDC below.
#   x402-org : Coinbase hosted, Base Sepolia TESTNET — no key, no gas. Best for dogfood.  (default)
#   cdp      : Coinbase CDP, Base MAINNET — requires FACILITATOR_API_KEY (CDP JWT).
#   self     : your own facilitator (AgentTools-Cloud/facilitator) — you run it, you pay gas.
#   <url>    : any https URL to a custom facilitator (then set NETWORK + USDC_ADDRESS_BASE).
FACILITATOR=x402-org
# Optional bearer token for facilitators that need one (custom / CDP).
FACILITATOR_API_KEY=

# --- chain / asset — leave BLANK to inherit from the facilitator preset above. ---
# Only set these when FACILITATOR is a custom URL, or to override a preset.
NETWORK=
USDC_ADDRESS_BASE=

# --- master key for encrypting sellers' upstream auth secrets at rest ---
# Generate with: python3 scripts/gen_keys.py
# Keep this file chmod 600. DO NOT COMMIT. Losing it = all stored upstream keys unreadable.
FERNET_KEY=

# --- admin token for the seller-approval / listing API ---
# Generate with: python3 scripts/gen_keys.py
ADMIN_TOKEN=

# --- ops ---
LOG_LEVEL=INFO
DB_PATH=/var/lib/agent-tools-hub/hub.db

# --- directory mirror (optional): push approved listings into agent-tools.cloud ---
DIRECTORY_SUBMIT_URL=
DIRECTORY_SUBMIT_TOKEN=
